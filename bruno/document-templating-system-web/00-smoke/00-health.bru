meta {
  name: 00 Health
  type: http
  seq: 1
  tags: smoke, contract
}

get {
  url: {{baseUrl}}/api/health
  body: none
  auth: none
}

tests {
  test("status is 200", function () {
    expect(res.status).to.equal(200);
  });

  test("health payload is ok", function () {
    const body = res.getBody();
    expect(body.ok).to.equal(true);
    expect(body.workspace).to.be.a("string").and.not.empty;
  });
}
